% if ( $ShowForm ) {
<form action="<% $FormAction || '?' %>" method="post">
  <div class="row mt-2">
    <div class="label col-auto">
      <&|/l&>Only show saved searches for:</&>
    </div>
    <div class="value col-auto">
      <select name="Type" class="form-select selectpicker">
        <option value="" <% !$Type && 'selected' %> ><% loc('(any)') %></option>
%     my %type = (
%         Asset => loc('Asset'),
%         AssetChart => loc('Asset Chart'),
%         Graph => loc('Graph'),
%         Ticket => loc('Ticket'),
%         TicketChart => loc('Ticket Chart'),
%         TicketTransaction => loc('Ticket Transaction'),
%         TicketTransactionChart => loc('Ticket Transaction Chart'),
%     );
%     for my $item ( sort keys %type ) {
        <option value="<% $item %>" <% $Type eq $item ? 'selected' : '' %> ><% $type{$item} %></option>
%     }
      </select>
    </div>
  </div>

  <div class="row mt-2">
    <div class="col-12">
      <div class="form-check">
        <input type="checkbox" class="form-check-input checkbox" id="IncludeDisabled" name="IncludeDisabled" value="1" <% $IncludeDisabled? 'checked': '' %> />
        <label class="form-check-label" for="IncludeDisabled"><&|/l&>Include disabled saved searches in listing.</&></label>
      </div>
    </div>
  </div>
  <& /Elements/Submit, Label => loc('Go!') &>
% }

<%perl>
$collection_index = 0;
foreach my $object (@objects) {
  my $saved_searches = $object->SavedSearches( Type => $Type );
  $saved_searches->FindAllRows if $IncludeDisabled;
  my $title;
  if (ref $object eq 'RT::User' && $object->Id == $session{CurrentUser}->Id) {
      $title = loc("My saved searches");
  } else {
      $title = loc("[_1]'s saved searches", $object->Name);
  }
  $title =~ s/([\\'])/\\$1/g;
  $title = $m->interp->apply_escapes($title, 'h');

my $format
    = $Type
    ? qq{'__Results__/TITLE:$title', __Disabled__}
    : qq{'__Results__/TITLE:$title', __Type__,__Disabled__};
if (   $ShowForm
    && $saved_searches->Count
    && RT::SavedSearch->new( $session{CurrentUser} )->CurrentUserCanModify($object) )
{
    $format
        = $Type
        ? qq{'__Results__/TITLE:$title', '__CheckBox.{Enabled}__/TITLE:Enabled'}
        : qq{'__Results__/TITLE:$title', __Type__, '__CheckBox.{Enabled}__/TITLE:Enabled'};
    $ShowSubmit = 1;
}
</%perl>
<& /Elements/CollectionList,
    %ARGS,
    Format => $format,
    Collection => $saved_searches,
    Page             => $DECODED_ARGS->{"SavedSearches-Page-$collection_index"} || 1,
    PageParam        => "SavedSearches-Page-$collection_index",
    PassArguments => [qw(Type IncludeDisabled RowsPerPage id)],
&>
<input type="hidden" name="Page-<% $collection_index %>" value="<% $DECODED_ARGS->{"SavedSearches-Page-$collection_index"} || 1 %>" />
% $collection_index++;
% }
% if ( $ShowForm ) {
%   if ($ShowSubmit) {
%     foreach my $id (@Enabled) {
      <input type="hidden" name="CurrentEnabled" value="<% $id %>" />
%     }
      <& /Elements/Submit, Name => 'Update', Label => loc('Update') &>
%   }
</form>
% }
<%INIT>
my $ShowSubmit = 0;
my @Enabled;
my @objects = $Object ? $Object : RT::SavedSearch->new($session{CurrentUser})->ObjectsForLoading();
$Rows ||= RT->Config->Get('DefaultSearchResultRowsPerPage');
# Initialize @Enabled with all enabled saved search IDs to populate the checkbox column
my $collection_index = 0;
foreach my $object (@objects) {
    my $saved_searches = $object->SavedSearches(Type => $Type);
    $saved_searches->FindAllRows if $IncludeDisabled;
    $saved_searches->RowsPerPage($Rows);
    $saved_searches->GotoPage(int($DECODED_ARGS->{"SavedSearches-Page-$collection_index"} || 1) - 1);
    while (my $saved_search = $saved_searches->Next) {
        push @Enabled, $saved_search->Id unless $saved_search->Disabled;
    }
    $collection_index++;
}
# __CheckBox column type only reads from DECODED_ARGS
$DECODED_ARGS->{Enabled} = \@Enabled;
</%INIT>

<%ARGS>
$Rows => undef
$IncludeDisabled => undef
$Type => ''
$Object => undef
$ShowForm => undef
$FormAction => undef
</%ARGS>

<%INIT>
return unless $Content && @$Content;

my @column_classes;
for my $item ( split /\s*,\s*/, $Layout // '' ) {
     # item is like 6-6, col-6-6, or col-md-4-8
    if ( $item =~ /^(\D+-)?([-\d]+)$/ ) {
        my $prefix = $1 || 'col-';
        push @column_classes, [ map { $prefix . $_ } split /-/, $2 ];
    }
    else {
        RT->Logger->warning("Unsupported layout item '$item'");
    }
}
</%INIT>

<%ARGS>
$ARGSRef => {}
$Content => undef
$Layout => undef
$InRow  => undef
$ExtraColumnClass => undef
</%ARGS>
